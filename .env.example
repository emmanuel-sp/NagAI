# Database
DB_NAME=nagai
DB_USER=nagai_user
DB_PASSWORD=CHANGE_ME_strong_password_here

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Gmail SMTP (use a Gmail App Password, not your normal password)
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Frontend URL (used in verification email links)
APP_BASE_URL=https://your-frontend.vercel.app

# CORS (comma-separated, no spaces after commas)
CORS_ORIGINS=https://your-frontend.vercel.app

# Backend public URL (used in email unsubscribe links)
BACKEND_BASE_URL=https://nagai-api.eastus.cloudapp.azure.com

# Internal API key — shared secret between backend and AI service
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# AI Service
ANTHROPIC_API_KEY=sk-ant-...
NEWSAPI_KEY=your-newsapi-key
